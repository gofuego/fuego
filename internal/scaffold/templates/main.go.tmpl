package main

import (
	"fmt"
	"os"

	"github.com/gofuego/fuego/engine"
	"github.com/gofuego/fuego/parsers/markdown"
{{- if .PackImport}}
	"{{.PackImport}}"
{{- end}}
)

func main() {
	eng := engine.New()

	// Fuego ships with zero built-in formats. Register the parsers you want.
	// Markdown is a first-party, opt-in parser:
	eng.Register(markdown.Parser())
{{- if .PackImport}}

	// Format pack installed via `fuego init --pack`. It brings its own
	// parsers, theme, config defaults, and hooks. Run `go run . config` to
	// see the resolved configuration.
	eng.Use({{.PackSymbol}}.Pack())
{{- end}}

	// Add your own formats with eng.Register(myParser), install a format
	// pack with eng.Use(somepack.Pack()), or transform pages with hooks:
	//   eng.AfterParse(fn)    // enrich/filter parsed pages
	//   eng.Index(fn)         // add virtual pages (collision-checked)
	//   eng.BeforeRender(fn)  // final transforms before HTML

	if err := eng.Run(os.Args); err != nil {
		fmt.Fprintf(os.Stderr, "fuego: %v\n", err)
		os.Exit(1)
	}
}
